            <!-- 日志格式：保留 Logger 名称（脚本名），便于区分不同 BOSS 脚本 -->
            <PatternLayout pattern="${log_pattern}"/>
            <!-- 滚动策略：与其他日志保持一致（每天归档+10MB拆分） -->
            <Policies>
                <TimeBasedTriggeringPolicy interval="${rolling_timeInterval}" modulate="true"/>
                <SizeBasedTriggeringPolicy size="${every_file_size}"/>
            </Policies>
            <!-- 旧日志清理：保留1天，超100MB自动删除（与登录/怪物日志逻辑统一） -->
            <DefaultRolloverStrategy max="${rolling_max}">
                <!-- basePath关联loggers日志输出类，改-->
                <Delete basePath="${command_log_path}" maxDepth="2">
                    <IfLastModified age="${age}"/>
                    <IfAccumulatedFileSize exceeds="${exceeds}" />
                </Delete>
            </DefaultRolloverStrategy>
        </RollingFile>

        <!-- 7.聊天日志输出器  -->
        <!-- 关联Properties日志配置，3个都改-->
        <RollingFile name="chatFile" fileName="${chat_fileName}" filePattern="${chat_filePattern}">
            <!-- 日志级别：脚本用 log.info()，设为 INFO 即可（避免冗余调试日志） -->
            <ThresholdFilter level="INFO" onMatch="ACCEPT" onMismatch="DENY"/>
            <!-- 日志格式：保留 Logger 名称（脚本名），便于区分不同 BOSS 脚本 -->
            <PatternLayout pattern="${log_pattern}"/>
            <!-- 滚动策略：与其他日志保持一致（每天归档+10MB拆分） -->
            <Policies>
