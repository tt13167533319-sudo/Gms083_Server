        </logger>

        <!-- 2.BOSS日志关联  -->
        <logger name="org.gms.server.expeditions.Expedition" level="INFO" additivity="false">
            <appender-ref ref="bossFile"/> <!-- 定向到 BOSS 专属日志文件 远征队-->
            <appender-ref ref="defaultFile"/> <!-- 同时输出到控制台（可选） -->
            <appender-ref ref="Console"/>
        </logger>
        <logger name="AreaBoss" level="INFO" additivity="false">
