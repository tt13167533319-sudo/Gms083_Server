    <loggers>
        <!-- 1. 登录相关类/包：输出到登录日志 -->
        <!-- 匹配 LoginPasswordHandler 所在的包路径 -->
        <logger name="org.gms.net.server.handlers.login" level="DEBUG" additivity="false">
            <appender-ref ref="loginFile"/> <!-- 登录日志文件 -->
            <appender-ref ref="defaultFile"/> <!-- 同时输出到控制台（可选） -->
            <appender-ref ref="Console"/>
        </logger>
        <logger name="org/gms/net/server/channel/handlers/PlayerLoggedinHandler" level="DEBUG" additivity="false">
            <appender-ref ref="loginFile"/> <!-- 登录日志文件 -->
            <appender-ref ref="defaultFile"/> <!-- 同时输出到控制台（可选） -->
            <appender-ref ref="Console"/>
        </logger>
        <logger name="org/gms/net/server/coordinator/session/SessionCoordinator" level="DEBUG" additivity="false">
            <appender-ref ref="loginFile"/> <!-- 登录日志文件 -->
            <appender-ref ref="defaultFile"/> <!-- 同时输出到控制台（可选） -->
            <appender-ref ref="Console"/>
        </logger>
        <logger name="org.gms.net.netty.ChannelServerInitializer" level="DEBUG" additivity="false">
            <appender-ref ref="loginFile"/> <!-- 登录日志文件 -->
            <appender-ref ref="defaultFile"/> <!-- 同时输出到控制台（可选） -->
