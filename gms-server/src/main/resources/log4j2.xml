                </Delete>
            </DefaultRolloverStrategy>
        </RollingFile>

        <!-- 6.命令日志输出器  -->
        <!-- 关联Properties日志配置，3个都改-->
        <RollingFile name="commandFile" fileName="${command_fileName}" filePattern="${command_filePattern}">
            <!-- 日志级别：脚本用 log.info()，设为 INFO 即可（避免冗余调试日志） -->
