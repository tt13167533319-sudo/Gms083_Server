            <appender-ref ref="defaultFile"/> <!-- 同时输出到控制台（可选） -->
            <appender-ref ref="Console"/>
        </logger>
        <logger name="org.gms.net.server.channel.handlers.AbstractDealDamageHandler" level="INFO" additivity="false">
            <appender-ref ref="autoBanFile"/> <!-- 定向到专属日志文件，改 -->
            <appender-ref ref="defaultFile"/> <!-- 同时输出到控制台（可选） -->
            <appender-ref ref="Console"/>
        </logger>

        <!-- 6.命令日志控制 name关联 -->
        <logger name="org.gms.client.command" level="INFO" additivity="false">
            <appender-ref ref="commandFile"/> <!-- 定向到专属日志文件，改 -->
            <appender-ref ref="defaultFile"/> <!-- 同时输出到控制台（可选） -->
            <appender-ref ref="Console"/>
        </logger>
        <logger name="org.gms.service.GiveService" level="INFO" additivity="false">
            <appender-ref ref="commandFile"/> <!-- 定向到专属日志文件，改 -->
            <appender-ref ref="defaultFile"/> <!-- 同时输出到控制台（可选） -->
            <appender-ref ref="Console"/>
        </logger>

        <!-- 7.聊天日志控制 name关联 -->
        <logger name="org.gms.server.ChatLogger" level="INFO" additivity="false">
            <appender-ref ref="chatFile"/> <!-- 定向到专属日志文件，改 -->
            <appender-ref ref="defaultFile"/> <!-- 同时输出到控制台（可选） -->
            <appender-ref ref="Console"/>
        </logger>

        <!-- 8.交易日志控制 name关联 -->
        <logger name="org.gms.server.Trade" level="INFO" additivity="false">
            <appender-ref ref="tradeFile"/> <!-- 定向到专属日志文件，改 -->
            <appender-ref ref="defaultFile"/> <!-- 同时输出到控制台（可选） -->
            <appender-ref ref="Console"/>
        </logger>
        <logger name="org.gms.net.server.channel.handlers.PlayerInteractionHandler" level="INFO" additivity="false">
            <appender-ref ref="tradeFile"/> <!-- 定向到专属日志文件，改 -->
            <appender-ref ref="defaultFile"/> <!-- 同时输出到控制台（可选） -->
            <appender-ref ref="Console"/>
        </logger>

        <!-- 9.抽奖日志控制 name关联 -->
        <logger name="org.gms.server.gachapon.Gachapon" level="INFO" additivity="false">
            <appender-ref ref="gachaponFile"/> <!-- 定向到专属日志文件，改 -->
            <appender-ref ref="defaultFile"/> <!-- 同时输出到控制台（可选） -->
            <appender-ref ref="Console"/>
        </logger>

        <!-- 10.商城日志控制 name关联 -->
        <logger name="org.gms.net.server.channel.handlers.CashOperationHandler" level="INFO" additivity="false">
            <appender-ref ref="cashshopFile"/> <!-- 定向到专属日志文件，改 -->
            <appender-ref ref="defaultFile"/> <!-- 同时输出到控制台（可选） -->
            <appender-ref ref="Console"/>
        </logger>

        <!-- 第三方框架日志控制 -->
        <logger name="com.alibaba.druid" level="ERROR">
            <appender-ref ref="Console"/>
            <appender-ref ref="defaultFile"/>
        </logger>
        <logger name="org.flywaydb" level="ERROR">
            <appender-ref ref="Console"/>
            <appender-ref ref="defaultFile"/>
        </logger>

        <!-- 其他所有日志：输出到默认日志 -->
        <root level="${output_log_level}">
            <appender-ref ref="defaultFile"/>
            <appender-ref ref="Console"/>
        </root>

    </loggers>


</configuration>

